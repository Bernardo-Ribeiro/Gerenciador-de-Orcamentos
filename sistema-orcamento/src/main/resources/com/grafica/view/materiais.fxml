<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="page" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.MaterialController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
    </padding>
    <children>
        <Label styleClass="breadcrumb" text="Dashboard   >   Cadastros   >   Materiais" />

        <VBox spacing="6.0">
            <children>
                <Label styleClass="page-title" text="Catálogo de Materiais" />
                <Label styleClass="page-subtitle" text="Gerencie os materiais e serviços para composição de orçamentos." wrapText="true" />
            </children>
        </VBox>

        <HBox spacing="16.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="12.0" styleClass="card form-card">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="card-title" text="Novo Cadastro" />
                                <Label styleClass="card-subtitle" text="Preencha os dados do material ou serviço." wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Nome" />
                                <TextField fx:id="nomeField" promptText="Ex: Lona Brilho 440g" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Categoria" />
                                <ComboBox fx:id="categoriaCombo" promptText="Selecione" styleClass="form-input" maxWidth="Infinity" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Tipo de Item" />
                                <ComboBox fx:id="tipoItemCombo" promptText="Selecione" styleClass="form-input" maxWidth="Infinity" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Tipo de Cobrança" />
                                <ComboBox fx:id="tipoCobrancaCombo" promptText="Selecione" styleClass="form-input" maxWidth="Infinity" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Custo Base (R$)" />
                                <TextField fx:id="custoBaseField" promptText="0.00" styleClass="form-input" />
                            </children>
                        </VBox>
                        
                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Custo Produção (R$)" />
                                <TextField fx:id="custoProducaoField" promptText="0.00" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Button text="Salvar Material" onAction="#salvarMaterial" maxWidth="Infinity" styleClass="btn-primary" />
                                <Button text="Limpar" onAction="#limpar" maxWidth="Infinity" styleClass="btn-secondary" />
                                <Button text="Deletar" onAction="#deletarMaterial" maxWidth="Infinity" styleClass="btn-danger" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="card-title" text="Base de Materiais" />
                                        <Label styleClass="card-subtitle" text="Visualize e filtre os itens cadastrados." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox spacing="8.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <ComboBox fx:id="filtroCategoria" promptText="Filtrar por Categoria" styleClass="form-input" />
                                        <Button onAction="#filtrar" text="Filtrar" styleClass="btn-secondary btn-icon" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <TableView fx:id="materiaisTable" VBox.vgrow="ALWAYS" styleClass="table">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" visible="false" />
                                <TableColumn fx:id="nomeColumn" text="Nome" prefWidth="200.0" />
                                <TableColumn fx:id="categoriaColumn" text="Categoria" prefWidth="130.0" />
                                <TableColumn fx:id="tipoItemColumn" text="Tipo Item" prefWidth="130.0" />
                                <TableColumn fx:id="tipoCobrancaColumn" text="Tipo Cobrança" prefWidth="130.0" />
                                <TableColumn fx:id="custoBaseColumn" text="Custo Base" prefWidth="100.0" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
