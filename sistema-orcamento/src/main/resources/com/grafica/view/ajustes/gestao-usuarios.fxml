                <HBox spacing="12.0" alignment="CENTER_LEFT">
                    <styleClass>
                        <String fx:value="users-table-row" />
                        <String fx:value="users-table-row-last" />
                    </styleClass>
                    <children>
                        <Label styleClass="users-table-value" text="Jorge Mendes" HBox.hgrow="ALWAYS" />
                        <Label styleClass="users-table-value" text="jorge@empresa.com" HBox.hgrow="ALWAYS" />
