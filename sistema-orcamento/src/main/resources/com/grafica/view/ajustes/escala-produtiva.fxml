<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="scale-section" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.EscalaProdutivaController">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>
    <children>
        <VBox spacing="6.0">
            <children>
                <Label styleClass="scale-title" text="Escala Produtiva" />
                <Label styleClass="scale-subtitle" text="Configure margens de desconto no preco unitario por intervalo de quantidade." wrapText="true" />
            </children>
        </VBox>

        <HBox spacing="16.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="12.0" styleClass="scale-card" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="scale-card-title" text="Tabela de Desconto Progressivo" />
                        <Label styleClass="scale-card-subtitle" text="Defina os intervalos e os percentuais aplicados automaticamente." wrapText="true" />

                        <HBox spacing="12.0" styleClass="scale-table-header" alignment="CENTER_LEFT">
                            <children>
                                <Label styleClass="scale-header-label" text="Qtd. Inicial" prefWidth="110.0" />
                                <Label styleClass="scale-header-label" text="Qtd. Final" prefWidth="110.0" />
                                <Label styleClass="scale-header-label" text="Desconto (%)" prefWidth="130.0" />
                                <Label styleClass="scale-header-label" text="Acoes" prefWidth="90.0" />
                            </children>
                        </HBox>

                        <VBox fx:id="rowsContainer" spacing="8.0" />

                        <Button onAction="#adicionarIntervalo" text="+ Adicionar Intervalo" maxWidth="Infinity" styleClass="scale-add-button" />
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="scale-sim-card" prefWidth="260.0">
                    <children>
                        <Label styleClass="scale-sim-title" text="Simulacao" />

                        <VBox spacing="8.0">
                            <children>
                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="scale-sim-label" text="Quantidade:" />
                                        <TextField fx:id="txtQuantidadeSimulacao" onKeyReleased="#atualizarSimulacao" promptText="0" styleClass="settings-input" prefWidth="110.0" />
                                        <Label styleClass="scale-sim-unit" text="un." />
                                    </children>
                                </HBox>

                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="scale-sim-label" text="Valor Base:" />
                                        <TextField fx:id="txtValorBaseSimulacao" onKeyReleased="#atualizarSimulacao" promptText="0.00" styleClass="settings-input" prefWidth="120.0" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="lblDescontoTitulo" styleClass="scale-sim-label" text="Desconto (0%):" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblDescontoValor" styleClass="scale-sim-negative" text="- R$ 0.00" />
                            </children>
                        </HBox>

                        <HBox spacing="6.0" alignment="CENTER_LEFT">
                            <children>
                                <Label styleClass="scale-total-label" text="Total Final:" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblTotalValor" styleClass="scale-total-value" text="R$ 0.00" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button onAction="#salvarEscala" text="Salvar Escala">
                    <styleClass>
                        <String fx:value="settings-action-button" />
                        <String fx:value="settings-primary-action" />
                    </styleClass>
                </Button>
            </children>
        </HBox>
    </children>
</VBox>