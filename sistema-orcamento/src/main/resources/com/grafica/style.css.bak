    -fx-alignment: center;
    -fx-background-color: #F2F4F7;
    -fx-text-fill: #344054;
    -fx-font-weight: 700;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
}

.dashboard-shortcut-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 12px;
    -fx-font-weight: 700;
}

.dashboard-shortcut-text {
    -fx-text-fill: #667085;
    -fx-font-size: 11px;
}

.dashboard-table-header {
    -fx-padding: 8 10;
    -fx-background-color: #FAFBFC;
    -fx-border-color: transparent transparent #E6EAF1 transparent;
    -fx-border-width: 0 0 1 0;
    -fx-background-radius: 8;
}

.dashboard-table-row {
    -fx-padding: 8 10;
    -fx-border-color: transparent transparent #EEF2F7 transparent;
    -fx-border-width: 0 0 1 0;
}

.dashboard-table-row-last {
    -fx-border-color: transparent;
}

.dashboard-table-label {
    -fx-text-fill: #667085;
    -fx-font-size: 11px;
    -fx-font-weight: 700;
}

.dashboard-table-value {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 11px;
}

.dashboard-pill {
    -fx-background-color: #F2F4F7;
    -fx-text-fill: #344054;
    -fx-border-color: #E4E7EC;
    -fx-border-width: 1;
    -fx-background-radius: 10;
    -fx-border-radius: 10;
    -fx-padding: 2 8;
    -fx-font-size: 10px;
    -fx-font-weight: 700;
}

.dashboard-pill-danger {
    -fx-background-color: #FDF2F2;
    -fx-text-fill: #B42318;
    -fx-border-color: #FECACA;
}

.dashboard-side {
    -fx-pref-width: 260px;
    -fx-min-width: 260px;
    -fx-max-width: 260px;
}

.dashboard-side-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 13px;
    -fx-font-weight: 700;
}

.dashboard-alert {
    -fx-background-color: #FFFFFF;
    -fx-border-color: #FEE2E2;
    -fx-border-width: 1;
    -fx-border-radius: 10;
    -fx-background-radius: 10;
    -fx-padding: 10;
}

.dashboard-alert-tag {
    -fx-text-fill: #D92D20;
    -fx-font-size: 10px;
    -fx-font-weight: 700;
}

.dashboard-alert-text {
    -fx-text-fill: #475467;
    -fx-font-size: 11px;
}

.dashboard-alert-time {
    -fx-text-fill: #98A2B3;
    -fx-font-size: 10px;
}

.dashboard-goal {
    -fx-alignment: center;
}

.dashboard-goal-icon {
    -fx-min-width: 36px;
    -fx-pref-width: 36px;
    -fx-min-height: 36px;
    -fx-pref-height: 36px;
    -fx-alignment: center;
    -fx-background-color: #F2F4F7;
    -fx-text-fill: #1F2A37;
    -fx-font-weight: 700;
    -fx-background-radius: 18;
    -fx-border-radius: 18;
}

.dashboard-goal-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 13px;
    -fx-font-weight: 700;
}

.dashboard-goal-text {
    -fx-text-fill: #667085;
    -fx-font-size: 11px;
    -fx-text-alignment: center;
}

/* Base Styles */
.title {
    -fx-font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    -fx-font-size: 36px;
    -fx-font-weight: 800;
    -fx-text-fill: #ffffff;
}

.subtitle {
    -fx-font-size: 18px;
    -fx-font-weight: 600;
    -fx-text-fill: rgba(255, 255, 255, 0.94);
}

.description {
    -fx-font-size: 14px;
    -fx-text-alignment: center;
    -fx-text-fill: rgba(255, 255, 255, 0.84);
}

.input {
    -fx-font-size: 14px;
    -fx-pref-height: 40;
    -fx-background-color: rgba(255, 255, 255, 0.95);
    -fx-background-radius: 9;
    -fx-border-radius: 9;
    -fx-border-color: #d9dde4;
    -fx-border-width: 1;
    -fx-padding: 0 12;
    -fx-text-fill: #111111;
}

.input:focused {
    -fx-border-color: #2b8be8;
}

/* Main Layout */
.main-header {
    -fx-background-color: #FAFAFBFF;
    -fx-padding: 12 24;
    -fx-border-color: transparent transparent #DEE1E6FF transparent;
    -fx-border-width: 0 0 1 0;
    -fx-alignment: center-left;
}

.main-title {
    -fx-font-size: 18px;
    -fx-font-weight: 700;
    -fx-text-fill: #1F2A37;
}

.main-user-label {
    -fx-font-size: 14px;
    -fx-font-weight: 600;
    -fx-text-fill: #565D6D;
}

.content-area {
    -fx-background-color: #F8FAFC;
}

/* Reports Specific */
.reports-input {
    -fx-pref-height: 38px;
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 8;
    -fx-border-color: #D9E0EA;
    -fx-border-width: 1;
    -fx-border-radius: 8;
    -fx-padding: 0 12;
    -fx-text-fill: #1F2A37;
}

.reports-input:focused {
    -fx-border-color: #2B8BE8;
}

/* Effects */
.frost {
    -fx-background-color: rgba(255, 255, 255, 0.05);
}

.text-body-sm {
    -fx-font-size: 12px;
    -fx-text-fill: #667085;
}
/* Garantir padding uniforme nos cards */
.settings-form-card,
.product-section-card {
    -fx-padding: 20 20 20 20;
}

/* Espaçamento entre os cards no detalhe */
.settings-detail-content {
    -fx-spacing: 28;
}

/* Altura mínima para tabelas de associação */
.product-section-card .table-view {
    -fx-pref-height: 150px;
    -fx-min-height: 100px;
}

/* Pequeno espaçamento acima dos HBox de adição */
.product-section-card .hbox {
    -fx-spacing: 10;
    -fx-padding: 6 0 0 0;
}

/* Evitar que a tabela principal fique sem altura mínima */
.settings-table-view {
    -fx-min-height: 200px;
}

/* Ajuste fino para o SplitPane, evitando que os painéis fiquem muito estreitos */
.split-pane > .split-pane-divider {
    -fx-padding: 0 2 0 2;
}
/* =====================================================
   GESTÃO DE PRODUTOS — estilos complementares
   ===================================================== */

/* Corrige padding interno dos cards de produto/formulário */
.produtos-detail-card {
    -fx-padding: 20;
}

.product-section-card {
    -fx-padding: 16 16 18 16;
}

/* Divisória sutil dentro do card de produto */
.produtos-divider {
    -fx-background-color: #EEF2F7;
}

/* Garante que o ScrollPane do painel direito não mostre borda */
.produtos-scroll {
    -fx-background-color: transparent;
    -fx-background: transparent;
    -fx-border-color: transparent;
}
.produtos-scroll > .viewport {
    -fx-background-color: transparent;
}

/* Painel esquerdo sem fundo extra */
.produtos-left-pane {
    -fx-background-color: transparent;
}
.produtos-right-pane {
    -fx-background-color: transparent;
}

/* SplitPane limpo */
.produtos-split {
    -fx-background-color: transparent;
    -fx-padding: 0;
}
.produtos-split > .split-pane-divider {
    -fx-padding: 0 3 0 3;
    -fx-background-color: #E6EAF1;
}

/* Garante que os botões de ação herdam o pref-height */
.settings-action-button {
    -fx-pref-height: 38px;
    -fx-padding: 0 16;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

/* Tabela principal de produtos com borda arredondada */
.settings-table-card {
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 12;
    -fx-border-color: #E6EAF1;
    -fx-border-width: 1;
    -fx-border-radius: 12;
    -fx-padding: 0;
}

/* Linha selecionada em azul claro nos cards de associação */
.product-section-card .settings-table-view .table-row-cell:selected {
    -fx-background-color: #EAF4FF;
}