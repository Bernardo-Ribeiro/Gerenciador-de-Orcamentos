/* Background */
.background {
    -fx-background-color: transparent;
}

.background-overlay {
    -fx-background-color: rgba(0, 0, 0, 0.25);
}

/* Layout wrappers */
.login-shell {
    -fx-alignment: center;
    -fx-spacing: 14;
    -fx-pref-width: 515px;
    -fx-pref-height: 429px;
    -fx-max-width: 535px;
    -fx-max-height: 470px;
}

.glass-card {
    -fx-alignment: center;
    -fx-spacing: 16;
    -fx-pref-width: 515px;
    -fx-pref-height: 368px;
    -fx-max-width: 522px;
    -fx-max-height: 420px;
}

.hero-copy {
    -fx-alignment: center;
    -fx-spacing: 6;
}

.field-group {
    -fx-alignment: center-left;
    -fx-spacing: 6;
    -fx-pref-width: 311px;
    -fx-max-width: 280px;
}

/* Card shell */
.card {
    -fx-background-color: transparent;
    -fx-padding: 30;
    -fx-background-radius: 18;
    -fx-border-radius: 18;
    -fx-border-color: rgba(255, 255, 255, 0.30);
    -fx-border-width: 1;
    -fx-max-width: 600;
    -fx-min-width: 400;
    -fx-pref-width: 420;
}

.glass {
    -fx-background-color: rgba(255, 255, 255, 0.15);
    -fx-background-radius: 20;
    -fx-border-radius: 20;
    -fx-border-color: rgba(255, 255, 255, 0.3);
    -fx-border-width: 1;
}

.glass .label {
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-text-fill: rgba(255, 255, 255, 0.90);
}

/* Specific label overrides must come after the generic .label rule.
   JavaFX Labels already carry the built-in style class "label". */
#titleLabel {
    -fx-font-family: "Segoe UI", "Helvetica Neue", Arial, sans-serif;
    -fx-font-size: 36px;
    -fx-font-weight: 800;
    -fx-pref-height: 53px;
    -fx-pref-width: 477px;
    -fx-text-fill: #ffffff;
}

#subtitleLabel {
    -fx-font-size: 18px;
    -fx-font-weight: 600;
    -fx-text-fill: rgba(255, 255, 255, 0.94);
}

#descLabel {
    -fx-font-size: 14px;
    -fx-text-alignment: center;
    -fx-text-fill: rgba(255, 255, 255, 0.84);
}

.glass .input {
    -fx-font-size: 14px;
    -fx-pref-height: 40;
    -fx-max-width: 280px;
    -fx-background-color: rgba(255, 255, 255, 0.95);
    -fx-background-radius: 9;
    -fx-border-radius: 9;
    -fx-border-color: #d9dde4;
    -fx-border-width: 1;
    -fx-padding: 0 12;
    -fx-prompt-text-fill: #a1a7b3;
    -fx-text-fill: #111111;
}

.glass .input:focused {
    -fx-border-color: #2b8be8;
}

.glass .btn {
    -fx-font-size: 14px;
    -fx-font-weight: 700;
    -fx-pref-height: 44;
    -fx-background-color: linear-gradient(to right, #2b8be8, #1f6fd6);
    -fx-background-radius: 10;
    -fx-text-fill: white;
    -fx-cursor: hand;
}

.glass .btn:hover {
    -fx-background-color: linear-gradient(to right, #237ce0, #1a63c0);
}

.feedback {
    -fx-font-size: 18px;
    -fx-text-alignment: center;
}

.feedback-error {
    -fx-text-fill: #c0392b;
}

.feedback-success {
    -fx-text-fill: #1f7a3f;
}

.card-separator {
    -fx-opacity: 0.8;
}

.footer {
    -fx-font-size: 11px;
    -fx-text-fill: rgba(255, 255, 255, 0.72);
}

.bottom-text {
    -fx-font-size: 10px;
    -fx-text-fill: rgba(255, 255, 255, 0.62);
}

/* Sidebar container */
.sidebar-menu {
    -fx-background-color: #FAFAFBFF;
    -fx-padding: 16 8 16 8;
    -fx-spacing: 16;
    -fx-alignment: top-left;
    -fx-pref-width: 256px;
    -fx-min-width: 256px;
    -fx-max-width: 256px;
}

/* Main sidebar buttons */
.sidebar-menu .button {
    -fx-pref-width: 223px;
    -fx-min-width: 223px;
    -fx-max-width: 223px;
    -fx-pref-height: 44px;
    -fx-min-height: 44px;
    -fx-max-height: 44px;
    -fx-padding: 0 12px;
    -fx-alignment: center;
    -fx-content-display: left;
    -fx-graphic-text-gap: 12px;
    -fx-font-family: "Open Sans", "Segoe UI", Arial, sans-serif;
    -fx-font-size: 14px;
    -fx-font-weight: 500;
    -fx-text-fill: #565D6D;
    -fx-background-color: transparent;
    -fx-opacity: 1;
    -fx-background-radius: 6;
    -fx-border-radius: 6;
    -fx-border-width: 0;
    -fx-border-color: transparent;
    -fx-cursor: hand;
}

.sidebar-menu .button:hover {
    -fx-text-fill: #1E2128FF;
    -fx-background-color: #F3F4F6FF;
}

.sidebar-menu .button:pressed {
    -fx-text-fill: #1E2128FF;
    -fx-background-color: #F3F4F6FF;
}

.sidebar-menu .button.active {
    -fx-text-fill: #258CF4;
    -fx-background-color: #E3F0FFFF;
    -fx-font-weight: 600;
}

.sidebar-menu .button.active .icon {
    -fx-fill: #258CF4;
}

.sidebar-menu .button:disabled {
    -fx-opacity: 0.4;
}

.sidebar-menu .button .icon {
    -fx-fit-width: 20px;
    -fx-fit-height: 20px;
    -fx-fill: #565D6D;
}

/* Sidebar separator */
.sidebar-separator {
    -fx-padding: 0;
    -fx-border-color: #DEE1E6FF;
    -fx-border-width: 1 0 0 0;
}

/* Exit button */
.sidebar-menu .button.btn-sair {
    -fx-pref-width: 223px;
    -fx-min-width: 223px;
    -fx-max-width: 223px;
    -fx-pref-height: 40px;
    -fx-min-height: 40px;
    -fx-padding: 0 12px;
    -fx-alignment: center;
    -fx-content-display: left;
    -fx-graphic-text-gap: 12px;
    -fx-font-family: "Open Sans", "Segoe UI", Arial, sans-serif;
    -fx-font-size: 14px;
    -fx-font-weight: 500;
    -fx-text-fill: #E83030FF;
    -fx-background-color: transparent;
    -fx-opacity: 1;
    -fx-background-radius: 6;
    -fx-border-radius: 6;
    -fx-border-width: 0;
    -fx-border-color: transparent;
    -fx-cursor: hand;
}

.sidebar-menu .button.btn-sair:hover {
    -fx-text-fill: #E83030FF;
    -fx-background-color: transparent;
}

.sidebar-menu .button.btn-sair:pressed {
    -fx-text-fill: #E83030FF;
    -fx-background-color: transparent;
}

.sidebar-menu .button.btn-sair .icon {
    -fx-fill: #E83030FF;
}

/* =========================
   CARD
========================= */


.materials-page {
    -fx-background-color: #F8FAFC;
}

.materials-breadcrumb {
    -fx-text-fill: #7A8090;
    -fx-font-size: 12px;
    -fx-font-weight: 500;
}

.materials-content-row {
    -fx-padding: 2 0 0 0;
}

.materials-form-card {
    -fx-pref-width: 320px;
    -fx-min-width: 320px;
    -fx-max-width: 320px;
}

.materials-card-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 15px;
    -fx-font-weight: 700;
}

.materials-card-subtitle {
    -fx-text-fill: #667085;
    -fx-font-size: 12px;
}

.materials-input {
    -fx-pref-height: 38px;
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 8;
    -fx-border-color: #D9E0EA;
    -fx-border-width: 1;
    -fx-border-radius: 8;
    -fx-padding: 0 12;
    -fx-text-fill: #1F2A37;
}

.materials-input:focused {
    -fx-border-color: #2B8BE8;
}

.materials-primary-button {
    -fx-pref-height: 38px;
    -fx-background-color: #2B8BE8;
    -fx-text-fill: white;
    -fx-border-color: #2B8BE8;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

.materials-primary-button:hover {
    -fx-background-color: #237CE0;
}

.materials-secondary-button {
    -fx-pref-height: 38px;
    -fx-background-color: #FFFFFF;
    -fx-text-fill: #344054;
    -fx-border-color: #D9E0EA;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

.materials-secondary-button:hover {
    -fx-background-color: #F8FAFC;
}

.materials-icon-button {
    -fx-padding: 0 12;
}
.materials-card {
    -fx-background-color: white;
    -fx-background-radius: 12;
    -fx-border-color: #e5e7eb;
    -fx-border-radius: 12;
    -fx-border-width: 1;
}

.materials-card.scroll-pane {
    -fx-background-color: white;
    -fx-background: white;
}
.materials-card.scroll-pane > .viewport {
    -fx-background-color: white;
}

/* =========================
   TOOLBAR
========================= */

.materials-search {
    -fx-pref-height: 40;
    -fx-background-color: white;
    -fx-border-color: #dbe2ea;
    -fx-border-radius: 8;
    -fx-background-radius: 8;
    -fx-padding: 0 14;
    -fx-font-size: 13px;
}

.materials-search:focused {
    -fx-border-color: #2563eb;
}

.materials-button {
    -fx-pref-height: 40;
    -fx-background-color: white;
    -fx-border-color: #dbe2ea;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-padding: 0 14;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

.materials-button:hover {
    -fx-background-color: #f9fafb;
}

/* =========================
   HEADER
========================= */

.materials-header {
    -fx-background-color: #f8fafc;
    -fx-padding: 14 18;
    -fx-border-color: transparent transparent #e5e7eb transparent;
    -fx-border-width: 1;
}

.materials-header-label {
    -fx-font-size: 13px;
    -fx-font-weight: 700;
    -fx-text-fill: #667085;
}

/* =========================
   LINHAS
========================= */

.materials-row {
    -fx-background-color: white;
    -fx-padding: 16 18;
    -fx-min-height: 56;
    -fx-border-color: transparent transparent #eef2f7 transparent;
    -fx-border-width: 1;
}

.materials-row:hover {
    -fx-background-color: #f9fafb;
}

/* linha destacada */
.materials-row-warning {
    -fx-background-color: #fff5f5;
}

.materials-row-warning:hover {
    -fx-background-color: #ffecec;
}

/* =========================
   TEXTOS
========================= */

.materials-text {
    -fx-font-size: 13px;
    -fx-text-fill: #1f2937;
}

.materials-text-muted {
    -fx-font-size: 13px;
    -fx-text-fill: #667085;
}

.materials-price-danger {
    -fx-font-size: 13px;
    -fx-font-weight: 700;
    -fx-text-fill: #ef4444;
}

/* =========================
   BADGES
========================= */

.materials-badge {
    -fx-background-color: #f3f4f6;
    -fx-border-color: #e5e7eb;

    -fx-background-radius: 999;
    -fx-border-radius: 999;

    -fx-padding: 2 10;

    -fx-font-size: 10px;
    -fx-font-weight: 700;

    -fx-text-fill: #475467;
}

/* alerta vermelho */

.materials-badge-danger {
    -fx-background-color: #ef4444;
    -fx-text-fill: white;
    -fx-background-radius: 999;
    -fx-padding: 2 8;
    -fx-font-size: 10px;
    -fx-font-weight: 700;
}

/* =========================
   AÇÕES
========================= */

.materials-action {
    -fx-background-color: transparent;
    -fx-border-color: transparent;

    -fx-font-size: 18px;
    -fx-text-fill: #667085;

    -fx-cursor: hand;
}

.materials-action:hover {
    -fx-text-fill: #111827;
}

.materials-link-button {
    -fx-background-color: transparent;
    -fx-border-color: transparent;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-text-fill: #D92D20;
    -fx-cursor: hand;
    -fx-padding: 0 8;
}

.materials-link-button:hover {
    -fx-text-fill: #B42318;
}

.radio-button {
    -fx-font-size: 13px;
}

.radio-button .radio {
    -fx-background-color: white;
    -fx-border-color: #D9E0EA;
    -fx-border-width: 1;
    -fx-background-radius: 10;
    -fx-border-radius: 10;
    -fx-padding: 2;
}

.radio-button:selected .radio {
    -fx-background-color: #2563eb;
    -fx-border-color: #2563eb;
}

.radio-button:selected .dot {
    -fx-background-color: white;
}

/* =========================
   PAGINAÇÃO
========================= */

.materials-pagination {
    -fx-pref-height: 30;

    -fx-background-color: white;
    -fx-border-color: #dbe2ea;

    -fx-background-radius: 8;
    -fx-border-radius: 8;

    -fx-padding: 0 12;

    -fx-font-size: 12px;
    -fx-font-weight: 600;

    -fx-text-fill: #475467;

    -fx-cursor: hand;
}

.materials-pagination:hover {
    -fx-background-color: #f9fafb;
}

.materials-pagination-active {
    -fx-background-color: #2563eb;
    -fx-border-color: #2563eb;
    -fx-text-fill: white;
}

.materials-footer {
    -fx-font-size: 12px;
    -fx-text-fill: #667085;
}
/* TITULOS */

.materials-title {
    -fx-font-size: 22px;
    -fx-font-weight: 700;
    -fx-text-fill: #111827;
}

.materials-subtitle {
    -fx-font-size: 13px;
    -fx-text-fill: #667085;
}

/* LABELS */

.materials-label {
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-text-fill: #374151;
}

/* TABLEVIEW */

.materials-table {
    -fx-background-color: white;
    -fx-border-color: #e5e7eb;
    -fx-border-radius: 10;
    -fx-background-radius: 10;
}

.materials-table .column-header-background {
    -fx-background-color: #f8fafc;
    -fx-background-radius: 10 10 0 0;
}

.materials-table .column-header {
    -fx-background-color: transparent;
    -fx-border-color: transparent transparent #e5e7eb transparent;
}

.materials-table .label {
    -fx-text-fill: #667085;
    -fx-font-size: 13px;
    -fx-font-weight: 700;
}

.materials-table .table-row-cell {
    -fx-background-color: white;
    -fx-border-color: transparent transparent #eef2f7 transparent;
    -fx-padding: 6 0;
}

.materials-table .table-row-cell:hover {
    -fx-background-color: #f9fafb;
}

.materials-table .table-cell {
    -fx-text-fill: #111827;
    -fx-font-size: 13px;
    -fx-border-color: transparent;
}

/* ALERTA */

.materials-alert {
    -fx-background-color: #fff7ed;
    -fx-border-color: #fed7aa;
    -fx-border-radius: 10;
    -fx-background-radius: 10;
    -fx-padding: 14;
}

.materials-alert-icon {
    -fx-background-color: #fb923c;
    -fx-background-radius: 999;

    -fx-text-fill: white;
    -fx-font-weight: 700;

    -fx-min-width: 22;
    -fx-min-height: 22;

    -fx-alignment: center;
}

.materials-alert-title {
    -fx-font-size: 13px;
    -fx-font-weight: 700;
    -fx-text-fill: #9a3412;
}

.materials-alert-text {
    -fx-font-size: 12px;
    -fx-text-fill: #c2410c;
}

.materials-alert-link {
    -fx-font-size: 12px;
    -fx-font-weight: 700;
    -fx-text-fill: #ea580c;
}

/* Settings screen */
.settings-page {
    -fx-background-color: #ffffff;
}

.settings-warning {
    -fx-background-color: #FFE8E8;
    -fx-border-color: #F7C2C2;
    -fx-border-width: 1;
    -fx-border-radius: 10;
    -fx-background-radius: 10;
    -fx-padding: 14 18 14 18;
    -fx-alignment: center-left;
}

.settings-warning-icon {
    -fx-min-width: 30px;
    -fx-pref-width: 30px;
    -fx-max-width: 30px;
    -fx-min-height: 30px;
    -fx-pref-height: 30px;
    -fx-max-height: 30px;
    -fx-alignment: center;
    -fx-background-color: rgba(255, 255, 255, 0.72);
    -fx-background-radius: 15;
    -fx-border-color: #FF7A7A;
    -fx-border-width: 1;
    -fx-border-radius: 15;
    -fx-text-fill: #FF4D4D;
    -fx-font-size: 18px;
    -fx-font-weight: 800;
}

.settings-warning-title {
    -fx-text-fill: #FF5A5A;
    -fx-font-size: 15px;
    -fx-font-weight: 700;
}

.settings-warning-text {
    -fx-text-fill: #E16767;
    -fx-font-size: 12px;
}

.settings-breadcrumb {
    -fx-text-fill: #7A8090;
    -fx-font-size: 12px;
    -fx-font-weight: 500;
}

.settings-content-row {
    -fx-padding: 2 0 0 0;
}

.settings-nav {
    -fx-pref-width: 235px;
    -fx-min-width: 235px;
    -fx-max-width: 235px;
}

.settings-nav-item {
    -fx-pref-width: 235px;
    -fx-min-width: 235px;
    -fx-max-width: 235px;
    -fx-pref-height: 40px;
    -fx-min-height: 40px;
    -fx-padding: 0 16px;
    -fx-background-color: transparent;
    -fx-background-radius: 8;
    -fx-border-color: transparent;
    -fx-border-radius: 8;
    -fx-alignment: center-left;
    -fx-text-fill: #666D7C;
    -fx-font-size: 13px;
    -fx-font-weight: 500;
    -fx-cursor: hand;
}

.settings-nav-item:hover {
    -fx-background-color: #F6F7FA;
    -fx-text-fill: #1F2A37;
}

.settings-nav-item.active {
    -fx-text-fill: #258CF4;
    -fx-background-color: #E3F0FFFF;
    -fx-font-weight: 500;
}

.settings-placeholder {
    -fx-background-color: transparent;
}

.settings-content-panel {
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 12;
    -fx-border-color: #E5EAF2;
    -fx-border-width: 1;
    -fx-border-radius: 12;
    -fx-padding: 20;
}

.settings-section {
    -fx-background-color: transparent;
    -fx-spacing: 12;
}

.settings-section-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 20px;
    -fx-font-weight: 700;
}

.settings-section-text {
    -fx-text-fill: #667085;
    -fx-font-size: 13px;
    -fx-wrap-text: true;
}

.settings-section-card {
    -fx-background-color: #F8FAFC;
    -fx-background-radius: 10;
    -fx-border-color: #E5EAF2;
    -fx-border-width: 1;
    -fx-border-radius: 10;
    -fx-padding: 16;
}

.settings-section-card-title {
    -fx-text-fill: #344054;
    -fx-font-size: 14px;
    -fx-font-weight: 700;
}

.settings-section-card-text {
    -fx-text-fill: #667085;
    -fx-font-size: 12px;
    -fx-wrap-text: true;
}

/* Product management screen */
.product-section-card {
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 12;
    -fx-border-color: #E6EAF1;
    -fx-border-width: 1;
    -fx-border-radius: 12;
    -fx-padding: 16;
}

.product-section-title {
    -fx-text-fill: #1F2A37;
    -fx-font-size: 14px;
    -fx-font-weight: 700;
}

/* Costs / CRUD screen */
.settings-crud-grid {
    -fx-padding: 4 0 0 0;
}

.settings-table-card,
.settings-form-card {
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 12;
    -fx-border-color: #E6EAF1;
    -fx-border-width: 1;
    -fx-border-radius: 12;
    -fx-padding: 0;
}

.settings-form-card {
    -fx-pref-width: 340px;
    -fx-min-width: 340px;
    -fx-max-width: 340px;
}

.settings-input {
    -fx-pref-height: 38px;
    -fx-background-color: #FFFFFF;
    -fx-background-radius: 8;
    -fx-border-color: #D9E0EA;
    -fx-border-width: 1;
    -fx-border-radius: 8;
    -fx-padding: 0 12;
    -fx-text-fill: #1F2A37;
}

.settings-input:focused {
    -fx-border-color: #2B8BE8;
}

.settings-search-field {
    -fx-pref-width: 320px;
}

.settings-form-label {
    -fx-text-fill: #475467;
    -fx-font-size: 12px;
    -fx-font-weight: 700;
}

.settings-action-button {
    -fx-pref-height: 38px;
    -fx-padding: 0 14;
    -fx-background-radius: 8;
    -fx-border-radius: 8;
    -fx-font-size: 13px;
    -fx-font-weight: 600;
    -fx-cursor: hand;
}

.settings-primary-action {
    -fx-background-color: #2B8BE8;
    -fx-text-fill: white;
    -fx-border-color: #2B8BE8;
}

.settings-primary-action:hover {
    -fx-background-color: #237CE0;
}

.settings-secondary-action {
    -fx-background-color: #FFFFFF;
    -fx-text-fill: #344054;
    -fx-border-color: #D9E0EA;
}

.settings-secondary-action:hover {
    -fx-background-color: #F8FAFC;
}

.settings-danger-action {
    -fx-background-color: #FFF5F5;
    -fx-text-fill: #D92D20;
    -fx-border-color: #FECACA;
}

.settings-danger-action:hover {
