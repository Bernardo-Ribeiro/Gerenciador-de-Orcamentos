<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="page" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.ClienteController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
    </padding>
    <children>
        <Label styleClass="breadcrumb" text="Dashboard   >   Cadastros   >   Clientes" />

        <VBox spacing="6.0">
            <children>
                <Label styleClass="page-title" text="Gestão de Clientes" />
                <Label styleClass="page-subtitle" text="Mantenha sua base de dados organizada para agilizar a criação de novos orçamentos." wrapText="true" />
            </children>
        </VBox>

        <HBox spacing="16.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="12.0" styleClass="card form-card">
                    <children>
                        <VBox spacing="4.0">
                            <children>
                                <Label styleClass="card-title" text="Novo Cadastro" />
                                <Label styleClass="card-subtitle" text="Preencha os dados abaixo para registrar um novo cliente." wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Nome / Razão Social" />
                                <TextField fx:id="nomeField" promptText="Ex: Empresa Exemplo LTDA" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="CPF / CNPJ" />
                                <TextField fx:id="cpfCnpjField" promptText="000.000.000-00 ou 00.000.000/0001-00" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="E-mail de Contato" />
                                <TextField fx:id="emailField" promptText="cliente@exemplo.com.br" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="form-label" text="Telefone / WhatsApp" />
                                <TextField fx:id="telefonejField" promptText="(00) 00000-0000" styleClass="form-input" />
                            </children>
                        </VBox>

                        <VBox spacing="8.0">
                            <children>
                                <Button text="Cadastrar Cliente" onAction="#salvarCliente" maxWidth="Infinity" styleClass="btn-primary" />
                                <Button text="Limpar" onAction="#novoCliente" maxWidth="Infinity" styleClass="btn-secondary" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="card" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" maxWidth="Infinity">
                    <children>
                        <HBox spacing="12.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <children>
                                <VBox spacing="4.0" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <children>
                                        <Label styleClass="card-title" text="Base de Clientes" />
                                        <Label styleClass="card-subtitle" text="Gerencie seus contatos e visualize o historico rapido." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox spacing="8.0" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <children>
                                        <TextField fx:id="txtBusca" onKeyReleased="#filtrarClientes" promptText="Buscar por nome ou documento..." styleClass="form-input search-input" />
                                        <Button fx:id="btnFiltros"
                                            onAction="#alternarFiltros"
                                            text="Filtros">
                                        <styleClass>
                                            <String fx:value="btn-secondary"/>
                                            <String fx:value="clients-icon-button"/>
                                        </styleClass>
                                    </Button>
                                    </children>
                                </HBox>
                            </children>
                        </HBox>

                        <HBox fx:id="filtersRow" spacing="10.0" alignment="CENTER_LEFT" visible="false" managed="false">
                            <children>
                                <Label styleClass="form-label" text="Status" />
                                <ComboBox fx:id="cmbStatusFiltro" onAction="#filtrarClientes" promptText="Selecione" styleClass="form-input" />
                                <Button onAction="#limparFiltros" text="Limpar filtros" styleClass="btn-secondary" />
                            </children>
                        </HBox>

                        <TableView fx:id="clientesTable" VBox.vgrow="ALWAYS" styleClass="table">
                            <columns>
                                <TableColumn fx:id="idColumn" text="ID" prefWidth="0.0" visible="false" />
                                <TableColumn fx:id="nomeColumn" text="Cliente" prefWidth="200.0" />
                                <TableColumn fx:id="cpfCnpjColumn" text="Documento" prefWidth="160.0" />
                                <TableColumn fx:id="emailColumn" text="Contato" prefWidth="220.0" />
                                <TableColumn fx:id="telefoneColumn" text="Telefone / WhatsApp" prefWidth="170.0" />
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                            </columns>
                        </TableView>

                        <HBox spacing="10.0" alignment="CENTER_LEFT">
                            <children>
                                <Label fx:id="lblRegistros" styleClass="table-footer" text="Mostrando 0 de 0 registros" />
                                <Region HBox.hgrow="ALWAYS" />
                                <HBox spacing="6.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button fx:id="btnAnterior" onAction="#paginaAnterior" text="Anterior" styleClass="btn-secondary" />
                                        <Button fx:id="btnPage1" onAction="#irParaPagina" text="1" styleClass="btn-secondary btn-secondary-dark" />
                                        <Button fx:id="btnPage2" onAction="#irParaPagina" text="2" styleClass="btn-secondary" />
                                        <Button fx:id="btnProximo" onAction="#paginaProxima" text="Próximo" styleClass="btn-secondary" />
                                    </children>
                                </HBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>