<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="settings-section" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.CustosInsumosController">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>
    <children>
        <HBox spacing="16.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="settings-section-title" text="Tabela de Custos de Insumos" />
                        <Label styleClass="settings-section-text" text="Gerencie os preços base de materiais e suprimentos da gráfica." wrapText="true" />
                    </children>
                </VBox>
                <Button fx:id="btnHistoricoGeral" onAction="#abrirHistoricoGeral" text="Histórico Geral">
                    <styleClass>
                        <String fx:value="settings-action-button" />
                        <String fx:value="settings-secondary-action" />
                    </styleClass>
                </Button>
                <Button fx:id="btnAdicionarNovoItem" onAction="#novoInsumo" text="+ Adicionar Novo Item">
                    <styleClass>
                        <String fx:value="settings-action-button" />
                        <String fx:value="settings-primary-action" />
                    </styleClass>
                </Button>
            </children>
        </HBox>

        <HBox spacing="12.0" alignment="CENTER_LEFT">
            <children>
                <TextField fx:id="txtBusca" onKeyReleased="#filtrarInsumos" promptText="Buscar material..." HBox.hgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="settings-input" />
                        <String fx:value="settings-search-field" />
                    </styleClass>
                </TextField>
                <Button fx:id="btnFiltros" onAction="#abrirFiltros" text="Filtros">
                    <styleClass>
                        <String fx:value="settings-action-button" />
                        <String fx:value="settings-secondary-action" />
                    </styleClass>
                </Button>
                <Button fx:id="btnExportarCsv" onAction="#exportarCsv" text="Exportar CSV">
                    <styleClass>
                        <String fx:value="settings-action-button" />
                        <String fx:value="settings-secondary-action" />
                    </styleClass>
                </Button>
            </children>
        </HBox>

        <HBox spacing="16.0" VBox.vgrow="ALWAYS" styleClass="settings-crud-grid">
            <children>
                <VBox spacing="10.0" styleClass="settings-table-card" HBox.hgrow="ALWAYS">
                    <children>
                        <TableView fx:id="tableInsumos" VBox.vgrow="ALWAYS" styleClass="settings-table-view">
                            <columns>
                                <TableColumn fx:id="colMaterial" prefWidth="310.0" text="Material" />
                                <TableColumn fx:id="colUnidade" prefWidth="110.0" text="Unidade" />
                                <TableColumn fx:id="colCustoBase" prefWidth="130.0" text="Custo Base (R$)" />
                                <TableColumn fx:id="colUltimaAtualizacao" prefWidth="150.0" text="Última Atualização" />
                                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                            </columns>
                        </TableView>

                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <children>
                                <Label styleClass="settings-table-footer" text="Mostrando itens cadastrados para a seção de custos." />
                            </children>
                        </HBox>
                    </children>
                </VBox>

                <VBox spacing="14.0" styleClass="settings-form-card">
                    <children>
                        <Label styleClass="settings-section-title" text="Detalhes do Insumo" />
                        <Label styleClass="settings-section-text" text="Selecione um item na tabela para editar ou preencha os campos para criar um novo registro." wrapText="true" />

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="settings-form-label" text="Material" />
                                <TextField fx:id="txtMaterial" promptText="Nome do material" styleClass="settings-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="settings-form-label" text="Categoria" />
                                <ComboBox fx:id="cmbCategoria" promptText="Selecione" styleClass="settings-input" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="settings-form-label" text="Unidade" />
                                <ComboBox fx:id="cmbUnidade" promptText="Selecione" styleClass="settings-input" />
                            </children>
                        </VBox>

                        <HBox spacing="12.0">
                            <children>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="settings-form-label" text="Custo Base" />
                                        <TextField fx:id="txtCustoBase" promptText="0,00" styleClass="settings-input" />
                                    </children>
                                </VBox>
                                <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="settings-form-label" text="Custo Produção" />
                                        <TextField fx:id="txtCustoProducao" promptText="0,00" styleClass="settings-input" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="6.0">
                            <children>
                                <Label styleClass="settings-form-label" text="Status" />
                                <ComboBox fx:id="cmbStatus" promptText="Selecione" styleClass="settings-input" />
                            </children>
                        </VBox>

                        <HBox spacing="10.0" alignment="CENTER_RIGHT">
                            <children>
                                <Button fx:id="btnExcluirSelecionado" onAction="#excluirSelecionado" text="Excluir">
                                    <styleClass>
                                        <String fx:value="settings-action-button" />
                                        <String fx:value="settings-danger-action" />
                                    </styleClass>
                                </Button>
                                <Button fx:id="btnLimparFormulario" onAction="#novoInsumo" text="Cancelar">
                                    <styleClass>
                                        <String fx:value="settings-action-button" />
                                        <String fx:value="settings-secondary-action" />
                                    </styleClass>
                                </Button>
                                <Button fx:id="btnSalvarInsumo" onAction="#salvarInsumo" text="Salvar">
                                    <styleClass>
                                        <String fx:value="settings-action-button" />
                                        <String fx:value="settings-primary-action" />
                                    </styleClass>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox styleClass="settings-alert-banner" spacing="12.0">
            <children>
                <Label styleClass="settings-alert-icon" text="i" />
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="settings-alert-title" text="Atenção Administrativa" />
                        <Label styleClass="settings-alert-text" text="Os preços base impactam diretamente os cálculos dos novos orçamentos." wrapText="true" />
                    </children>
                </VBox>
                <Label styleClass="settings-alert-link" text="Ver todos os desatualizados &gt;" />
            </children>
        </HBox>
    </children>
</VBox>