<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="materials-page" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.GestaoLayoutsController">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>

    <children>
        <HBox spacing="16.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="materials-title" text="Gestão de Layouts / Tamanhos Padrão" />
                        <Label styleClass="materials-subtitle" text="Configure medidas pré-definidas para agilizar a criação de orçamentos." wrapText="true" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <HBox spacing="16.0" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="10.0" styleClass="materials-card" HBox.hgrow="ALWAYS">
                    <children>
                        <TableView fx:id="layoutsTable" VBox.vgrow="ALWAYS" styleClass="materials-table">
                            <columns>
                                <TableColumn fx:id="materialColumn" text="Material" prefWidth="180.0" />
                                <TableColumn fx:id="nomeColumn" text="Nome do Layout" prefWidth="200.0" />
                                <TableColumn fx:id="larguraColumn" text="Largura (mm)" prefWidth="90.0" />
                                <TableColumn fx:id="alturaColumn" text="Altura (mm)" prefWidth="90.0" />
                                <TableColumn fx:id="acaoColumn" text="Ações" prefWidth="80.0" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="materials-card" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="14.0" prefWidth="320.0">
                            <children>
                                <Label styleClass="materials-title" text="Detalhes do Layout" />
                                <Label styleClass="materials-subtitle" text="Vincule um material e defina as dimensões padrão." wrapText="true" />

                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="materials-label" text="Material Vinculado" />
                                        <ComboBox fx:id="materialCombo" promptText="Selecione o material" maxWidth="Infinity" styleClass="materials-input" />
                                    </children>
                                </VBox>

                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="materials-label" text="Nome do Layout" />
                                        <TextField fx:id="nomeLayoutField" promptText="Ex: Cartão de Visita" styleClass="materials-input" />
                                    </children>
                                </VBox>

                                <HBox spacing="12.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="materials-label" text="Largura (mm)" />
                                                <TextField fx:id="larguraField" promptText="0" styleClass="materials-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="materials-label" text="Altura (mm)" />
                                                <TextField fx:id="alturaField" promptText="0" styleClass="materials-input" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button onAction="#limparCampos" text="Novo" styleClass="materials-secondary-button" />
                                        <Button fx:id="btnSalvar" onAction="#salvarLayout" text="Salvar" styleClass="materials-primary-button" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </HBox>
    </children>
</VBox>
