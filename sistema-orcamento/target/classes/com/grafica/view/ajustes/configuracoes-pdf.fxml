<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="page" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.ConfiguracoesPdfController">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>
    <children>

        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="card">
            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0" />
            </padding>
            <content>
                <VBox spacing="16.0">
                    <padding>
                        <Insets top="0.0" right="4.0" bottom="4.0" left="4.0" />
                    </padding>
                    <children>
                        <HBox spacing="16.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                                    <VBox spacing="10.0" styleClass="card">
                                        <children>
                                            <Label styleClass="card-title" text="Identidade Visual" />
                                            <Label styleClass="card-subtitle" text="A logomarca aparecerá no canto superior esquerdo do documento." wrapText="true" />
                                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                                <children>
                                                    <VBox styleClass="card">
                                                        <children>
                                                            <Label styleClass="text-muted" text="Logo" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Button text="Carregar Nova Logo" onAction="#carregarLogo" styleClass="btn-primary" />
                                                            <Label styleClass="helper-text" text="Recomendado: PNG ou JPG com fundo transparente. Max 2MB." wrapText="true" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="12.0" styleClass="card">
                                        <children>
                                            <Label styleClass="card-title" text="Dados da Empresa" />
                                            <Label styleClass="card-subtitle" text="Informações de contato e faturamento para o cabeçalho." wrapText="true" />

                                            <HBox spacing="12.0">
                                                <children>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Label styleClass="form-label" text="Nome Comercial" />
                                                            <TextField fx:id="txtNomeComercial" styleClass="form-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0">
                                                        <children>
                                                            <Label styleClass="form-label" text="CNPJ" />
                                                            <TextField fx:id="txtCnpj" styleClass="form-input" prefWidth="180.0" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>

                                            <HBox spacing="12.0">
                                                <children>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Label styleClass="form-label" text="Telefone / WhatsApp" />
                                                            <TextField fx:id="txtTelefone" styleClass="form-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Label styleClass="form-label" text="E-mail de Contato" />
                                                            <TextField fx:id="txtEmail" styleClass="form-input" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>

                                            <VBox spacing="6.0">
                                                <children>
                                                    <Label styleClass="form-label" text="Endereço Completo" />
                                                    <TextField fx:id="txtEndereco" styleClass="form-input" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <VBox spacing="12.0" styleClass="card">
                                        <children>
                                            <Label styleClass="card-title" text="Layout do Documento" />
                                            <Label styleClass="card-subtitle" text="Ajustes finos de impressão e observações legais." wrapText="true" />

                                            <HBox spacing="12.0">
                                                <children>
                                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                        <children>
                                                            <Label styleClass="form-label" text="Tamanho Papel" />
                                                            <TextField fx:id="txtTamanhoPapel" text="A4 (210 x 297mm)" styleClass="form-input" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0">
                                                        <children>
                                                            <Label styleClass="form-label" text="Margem Sup. (mm)" />
                                                            <TextField fx:id="txtMargemSuperior" text="15" styleClass="form-input" prefWidth="120.0" />
                                                        </children>
                                                    </VBox>
                                                    <VBox spacing="6.0">
                                                        <children>
                                                            <Label styleClass="form-label" text="Margem Lat. (mm)" />
                                                            <TextField fx:id="txtMargemLateral" text="10" styleClass="form-input" prefWidth="120.0" />
                                                        </children>
                                                    </VBox>
                                                </children>
                                            </HBox>

                                            <VBox spacing="6.0">
                                                <children>
                                                    <Label styleClass="form-label" text="Observações do Rodapé (Texto Fixo)" />
                                                    <TextArea fx:id="txtObservacoes" text="Este orçamento tem validade de 10 dias úteis. Garantia de 12 meses contra defeitos de fabricação." styleClass="form-input" wrapText="true" prefRowCount="3" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>

                                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                        <children>
                                            <Button text="Restaurar Padrões" onAction="#restaurarPadroes" styleClass="btn-secondary" />
                                            <Button text="Salvar Configurações" onAction="#salvarConfiguracoes" styleClass="btn-primary" />
                                        </children>
                                    </HBox>
                                </VBox>

                                <VBox spacing="12.0" styleClass="card">
                                    <children>
                                        <Label styleClass="card-title" text="Pré-visualização em Tempo Real" />

                                        <VBox spacing="8.0" styleClass="card-card">
                                            <children>
                                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Label styleClass="card-brand" text="" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label styleClass="card-logo" text="LOGO" />
                                                    </children>
                                                </HBox>
                                                <Label styleClass="card-text" text="" />
                                                <Label styleClass="card-text" text="" />
                                                <Label styleClass="card-text" text="" />
                                                <HBox spacing="6.0" alignment="CENTER_LEFT" styleClass="card-divider">
                                                    <children>
                                                        <Label styleClass="card-caption" text="ORÇAMENTO #2024-085" />
                                                        <Region HBox.hgrow="ALWAYS" />
                                                        <Label styleClass="card-caption" text="Emitido em 24/05/2024" />
                                                    </children>
                                                </HBox>
                                                <VBox spacing="4.0" styleClass="card-block">
                                                    <children>
                                                        <Label styleClass="card-placeholder" text="" />
                                                        <Label styleClass="card-placeholder" text="" />
                                                        <Label styleClass="card-placeholder" text="" />
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="note-card">
                                            <children>
                                                <Label styleClass="note-card-icon" text="i" />
                                                <Label styleClass="note-card-text" text="Layout responsivo para visualização em dispositivos móveis e impressão A4." wrapText="true" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

    </children>
</VBox>