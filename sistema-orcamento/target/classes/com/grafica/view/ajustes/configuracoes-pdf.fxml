<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="pdf-section" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>
    <children>
        <HBox spacing="16.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="16.0" HBox.hgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="pdf-card">
                        <children>
                            <Label styleClass="pdf-card-title" text="Identidade Visual" />
                            <Label styleClass="pdf-card-subtitle" text="A logomarca aparecera no canto superior esquerdo do documento." wrapText="true" />
                            <HBox spacing="12.0" alignment="CENTER_LEFT">
                                <children>
                                    <VBox styleClass="pdf-logo-preview">
                                        <children>
                                            <Label styleClass="pdf-logo-placeholder" text="Logo" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Button text="Carregar Nova Logo" styleClass="pdf-primary-button" />
                                            <Label styleClass="pdf-helper" text="Recomendado: PNG ou JPG com fundo transparente. Max 2MB." wrapText="true" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="12.0" styleClass="pdf-card">
                        <children>
                            <Label styleClass="pdf-card-title" text="Dados da Empresa" />
                            <Label styleClass="pdf-card-subtitle" text="Informacoes de contato e faturamento para o cabecalho." wrapText="true" />

                            <HBox spacing="12.0">
                                <children>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="Nome Comercial" />
                                            <TextField text="Serralheria Visual Pro" styleClass="settings-input" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="6.0">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="CNPJ" />
                                            <TextField text="12.345.678/0001-90" styleClass="settings-input" prefWidth="180.0" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <HBox spacing="12.0">
                                <children>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="Telefone / WhatsApp" />
                                            <TextField text="(11) 98765-4321" styleClass="settings-input" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="E-mail de Contato" />
                                            <TextField text="contato@visualpro.com.br" styleClass="settings-input" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="6.0">
                                <children>
                                    <Label styleClass="pdf-field-label" text="Endereco Completo" />
                                    <TextField text="Av. Industrial, 1500 - Bloco B, Sao Paulo - SP" styleClass="settings-input" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <VBox spacing="12.0" styleClass="pdf-card">
                        <children>
                            <Label styleClass="pdf-card-title" text="Layout do Documento" />
                            <Label styleClass="pdf-card-subtitle" text="Ajustes finos de impressao e observacoes legais." wrapText="true" />

                            <HBox spacing="12.0">
                                <children>
                                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="Tamanho Papel" />
                                            <TextField text="A4 (210 x 297mm)" styleClass="settings-input" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="6.0">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="Margem Sup. (mm)" />
                                            <TextField text="15" styleClass="settings-input" prefWidth="120.0" />
                                        </children>
                                    </VBox>
                                    <VBox spacing="6.0">
                                        <children>
                                            <Label styleClass="pdf-field-label" text="Margem Lat. (mm)" />
                                            <TextField text="10" styleClass="settings-input" prefWidth="120.0" />
                                        </children>
                                    </VBox>
                                </children>
                            </HBox>

                            <VBox spacing="6.0">
                                <children>
                                    <Label styleClass="pdf-field-label" text="Observacoes de Rodape (Texto Fixo)" />
                                    <TextArea text="Este orcamento tem validade de 10 dias uteis. Garantia de 12 meses contra defeitos de fabricacao." styleClass="pdf-textarea" wrapText="true" prefRowCount="3" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <HBox spacing="10.0" alignment="CENTER_RIGHT">
                        <children>
                            <Button text="Restaurar Padroes" styleClass="pdf-secondary-button" />
                            <Button text="Salvar Configuracoes" styleClass="pdf-primary-button" />
                        </children>
                    </HBox>
                </VBox>

                <VBox spacing="12.0" styleClass="pdf-preview">
                    <children>
                        <Label styleClass="pdf-preview-title" text="Pre-visualizacao em Tempo Real" />

                        <VBox spacing="8.0" styleClass="pdf-preview-card">
                            <children>
                                <HBox spacing="8.0" alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="pdf-preview-brand" text="Serralheria\nVisual Pro" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label styleClass="pdf-preview-logo" text="LOGO" />
                                    </children>
                                </HBox>
                                <Label styleClass="pdf-preview-text" text="CNPJ: 12.345.678/0001-90" />
                                <Label styleClass="pdf-preview-text" text="Av. Industrial, 1500 - Bloco B, Sao Paulo - SP" />
                                <Label styleClass="pdf-preview-text" text="(11) 98765-4321  contato@visualpro.com.br" />
                                <HBox spacing="6.0" alignment="CENTER_LEFT" styleClass="pdf-preview-divider">
                                    <children>
                                        <Label styleClass="pdf-preview-caption" text="ORCAMENTO #2024-085" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label styleClass="pdf-preview-caption" text="Emitido em 24/05/2024" />
                                    </children>
                                </HBox>
                                <VBox spacing="4.0" styleClass="pdf-preview-block">
                                    <children>
                                        <Label styleClass="pdf-preview-placeholder" text="" />
                                        <Label styleClass="pdf-preview-placeholder" text="" />
                                        <Label styleClass="pdf-preview-placeholder" text="" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                        <HBox spacing="8.0" alignment="CENTER_LEFT" styleClass="pdf-note">
                            <children>
                                <Label styleClass="pdf-note-icon" text="i" />
                                <Label styleClass="pdf-note-text" text="Layout responsivo para visualizacao em dispositivos moveis e impressao A4." wrapText="true" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>