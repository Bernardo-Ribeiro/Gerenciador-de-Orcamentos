<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="profit-section" stylesheets="@../../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.MargensLucroController">
    <padding>
        <Insets top="4.0" right="4.0" bottom="4.0" left="4.0" />
    </padding>
    <children>
        <HBox spacing="12.0" alignment="CENTER_LEFT">
            <children>
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="profit-title" text="Margens de Lucro Padrão" />
                        <Label styleClass="profit-subtitle" text="Gerencie as porcentagens de lucro por categoria para automatizar orçamentos." wrapText="true" />
                    </children>
                </VBox>
                <Button text="+ Nova Categoria" onAction="#novaCategoria" styleClass="profit-primary-button" />
            </children>
        </HBox>

        <HBox fx:id="alertSuccess" visible="false" managed="false" spacing="10.0" alignment="CENTER_LEFT" styleClass="profit-alert">
            <children>
                <Label styleClass="profit-alert-icon" text="OK" />
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="profit-alert-title" text="Configurações Atualizadas" />
                        <Label styleClass="profit-alert-text" text="As margens foram salvas com sucesso e já estão ativas para novos orçamentos." wrapText="true" />
                    </children>
                </VBox>
                <Label styleClass="profit-alert-link" text="Dispensar" onMouseClicked="#ocultarAlerta" />
            </children>
        </HBox>

        <!-- Scrollable area: inline form + bulk actions + category list -->
        <ScrollPane fitToWidth="true" fitToHeight="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="materials-card">
            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0" />
            </padding>
            <content>
                <VBox spacing="12.0">
                    <padding>
                        <Insets top="0.0" right="4.0" bottom="4.0" left="4.0" />
                    </padding>
                    <children>
                        <!-- Inline form for new category -->
                        <VBox fx:id="novoCategoriaForm" visible="false" managed="false" spacing="14.0" styleClass="profit-list-card">
                            <padding>
                                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
                            </padding>
                            <children>
                                <Label styleClass="profit-row-title" text="Nova Categoria de Lucro" />
                                <HBox spacing="12.0">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="settings-form-label" text="Nome da Categoria" />
                                                <TextField fx:id="txtNovaCategoriaNome" promptText="Ex: Comunicação Visual" styleClass="settings-input" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="settings-form-label" text="Margem Padrão (%)" />
                                                <TextField fx:id="txtNovaCategoriaMargem" promptText="50,00" styleClass="settings-input" prefWidth="100" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="6.0">
                                    <children>
                                        <Label styleClass="settings-form-label" text="Descrição" />
                                        <TextField fx:id="txtNovaCategoriaDescricao" promptText="Descrição opcional da categoria" styleClass="settings-input" />
                                    </children>
                                </VBox>
                                <HBox spacing="10.0" alignment="CENTER_RIGHT">
                                    <children>
                                        <Button text="Cancelar" onAction="#cancelarNovaCategoria" styleClass="settings-secondary-action, settings-action-button" />
                                        <Button text="Salvar" onAction="#salvarNovaCategoria" styleClass="settings-primary-action, settings-action-button" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="profit-bulk-row">
                            <children>
                                <CheckBox styleClass="profit-checkbox" />
                                <Label styleClass="profit-bulk-label" text="AÇÕES EM MASSA" />
                                <Label styleClass="profit-bulk-action" text="Aumentar 5%" />
                                <Label styleClass="profit-bulk-danger" text="Excluir Selecionados" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblCount" styleClass="profit-bulk-count" text="0 categorias listadas" />
                            </children>
                        </HBox>

                        <VBox fx:id="categoriasContainer" spacing="0.0" styleClass="profit-list-card">
                            <children>
                                <!-- Categorias dinâmicas aqui -->
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </content>
        </ScrollPane>

        <HBox alignment="CENTER_LEFT" styleClass="profit-footer">
            <children>
                <HBox spacing="6.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="profit-footer-icon" text="i" />
                        <Label styleClass="profit-footer-text" text="As alterações afetarão todos os orçamentos baseados nestas margens." />
                    </children>
                </HBox>
                <Button text="Cancelar Alterações" onAction="#cancelarAlteracoes" styleClass="profit-secondary-button" />
                <Button text="Salvar padrões" onAction="#salvarPadroes" styleClass="profit-primary-button" />
            </children>
        </HBox>
    </children>
</VBox>