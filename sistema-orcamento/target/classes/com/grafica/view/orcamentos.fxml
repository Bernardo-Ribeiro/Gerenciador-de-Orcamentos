<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import java.lang.String?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableCell?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.cell.PropertyValueFactory?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0" styleClass="budget-page" stylesheets="@../style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.grafica.controller.OrcamentoController">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
    </padding>
    <children>
        <Label styleClass="budget-breadcrumb" text="Operacional   >   Novo Orcamento   >   Calculadora" />

        <HBox spacing="18.0" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
            <children>
                <VBox spacing="14.0" HBox.hgrow="ALWAYS">
                    <VBox spacing="10.0" styleClass="budget-card">
                        <children>
                            <Label styleClass="budget-card-title" text="Identificacao do Cliente" />
                            <Label styleClass="budget-card-subtitle" text="Pesquisar Cliente (Nome ou CNPJ)" />
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <children>
                                    <ComboBox fx:id="clienteCombo" promptText="Pesquisar cliente..." HBox.hgrow="ALWAYS">
                                        <styleClass>
                                            <String fx:value="settings-input" />
                                            <String fx:value="budget-input" />
                                        </styleClass>
                                    </ComboBox>
                                    <Label styleClass="budget-chip" text="Autocomplete" />
                                    <Button text="+ Novo Cliente" styleClass="budget-secondary-button" />
                                </children>
                            </HBox>
                        </children>
                    </VBox>

                    <VBox spacing="10.0" styleClass="budget-card">
                        <children>
                            <Label styleClass="budget-card-title" text="Especificacoes Tecnicas" />
                            <VBox spacing="10.0">
                                <children>
                                    <HBox spacing="10.0">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label styleClass="budget-field-label" text="Material de Base" />
                                                            <ComboBox fx:id="materialCombo" promptText="Selecione o material" styleClass="settings-input" />
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0">
                                                <children>
                                                    <Label styleClass="budget-field-label" text="Largura (mm)" />
                                                            <TextField fx:id="larguraField" promptText="2500" styleClass="settings-input" prefWidth="120.0" />
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0">
                                                <children>
                                                    <Label styleClass="budget-field-label" text="Altura (mm)" />
                                                            <TextField fx:id="alturaField" promptText="1200" styleClass="settings-input" prefWidth="120.0" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                                        <children>
                                            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                                <children>
                                                    <Label styleClass="budget-field-label" text="Tipo de Servico / Acabamento" />
                                                            <TextField fx:id="acabamentoField" promptText="Selecione" styleClass="settings-input" />
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0">
                                                <children>
                                                    <Label styleClass="budget-field-label" text="Quantidade Total" />
                                                            <TextField fx:id="quantidadeField" promptText="5" styleClass="settings-input" prefWidth="120.0" />
                                                </children>
                                            </VBox>
                                            <VBox spacing="6.0" alignment="BOTTOM_RIGHT">
                                                <children>
                                                    <Button text="+ Adicionar" onAction="#adicionarItem" styleClass="budget-primary-button" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </HBox>

                                    <Label fx:id="areaCalculadaLabel" styleClass="budget-helper" text="* Area calculada: 0.00 m2" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <VBox spacing="10.0" styleClass="budget-card">
                        <children>
                            <HBox alignment="CENTER_LEFT">
                                <children>
                                    <Label fx:id="itensCountLabel" styleClass="budget-card-title" text="Itens do Orcamento (0)" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="orcamentoBadgeLabel" styleClass="budget-badge" text="ID: Novo" />
                                </children>
                            </HBox>

                            <HBox spacing="12.0" styleClass="budget-table-header" alignment="CENTER_LEFT">
                                <children>
                                    <Label styleClass="budget-table-label" text="Material / Servico" HBox.hgrow="ALWAYS" />
                                    <Label styleClass="budget-table-label" text="Dimensoes" prefWidth="140.0" />
                                    <Label styleClass="budget-table-label" text="Qtd" prefWidth="60.0" />
                                    <Label styleClass="budget-table-label" text="V. Bruto" prefWidth="90.0" />
                                    <Label styleClass="budget-table-label" text="V. Final" prefWidth="90.0" />
                                    <Label styleClass="budget-table-label" text="Acoes" prefWidth="60.0" />
                                </children>
                            </HBox>

                            <TableView fx:id="itensTable" VBox.vgrow="ALWAYS" styleClass="budget-table-view">
                                <columns>
                                    <TableColumn fx:id="materialColumn" text="Material / Servico" prefWidth="220.0" />
                                    <TableColumn fx:id="dimensoesColumn" text="Dimensoes" prefWidth="140.0" />
                                    <TableColumn fx:id="quantidadeItemColumn" text="Qtd" prefWidth="60.0" />
                                    <TableColumn fx:id="valorBrutoColumn" text="V. Bruto" prefWidth="90.0" />
                                    <TableColumn fx:id="valorFinalColumn" text="V. Final" prefWidth="90.0" />
                                    <TableColumn fx:id="acaoColumn" text="Acoes" prefWidth="80.0" />
                                </columns>
                            </TableView>
                        </children>
                    </VBox>
                </VBox>

                <VBox spacing="12.0" styleClass="budget-sidebar">
                    <children>
                        <Label styleClass="budget-sidebar-title" text="Monitor de Valores" />

                        <VBox spacing="6.0" styleClass="budget-summary-card">
                            <children>
                                <Label styleClass="budget-summary-label" text="Valor Bruto Acumulado" />
                                <Label fx:id="valorBrutoLabel" styleClass="budget-summary-value" text="R$ 0,00" />
                                <Label styleClass="budget-summary-muted" text="Baseado em custos de insumos e mao de obra" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="budget-summary-card">
                            <children>
                                <Label styleClass="budget-summary-label" text="Margem de Lucro Aplicada" />
                                <TextField fx:id="margemField" promptText="35.0" styleClass="settings-input" />
                                <Label styleClass="budget-summary-muted" text="Padrao configurado pelo Administrador" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="budget-summary-card">
                            <children>
                                <Label styleClass="budget-summary-label" text="Desconto Progressivo" />
                                <TextField fx:id="descuentoField" promptText="5.0" styleClass="settings-input" />
                                <Label styleClass="budget-summary-muted" text="Aplicado: Escala Padrao" wrapText="true" />
                            </children>
                        </VBox>

                        <VBox spacing="6.0" styleClass="budget-total-card">
                            <children>
                                <Label styleClass="budget-total-label" text="Valor Final do Orcamento" />
                                <Label fx:id="valorFinalLabel" styleClass="budget-total-value" text="R$ 0,00" />
                                <Label styleClass="budget-summary-muted" text="Valor sujeito a validade de 5 dias uteis" wrapText="true" />
                            </children>
                        </VBox>

                        <Button text="Salvar Orcamento" onAction="#criarOrcamento" styleClass="budget-primary-button" />
                        <Button text="Gerar Proposta PDF" styleClass="budget-secondary-button" />
                        <Button text="Limpar Tudo" onAction="#limparCampos" styleClass="budget-ghost-button" />

                        <VBox spacing="6.0" styleClass="budget-note-card">
                            <children>
                                <Label styleClass="budget-note-label" text="Os calculos consideram as dimensoes em milimetros e aplicam o custo por metro quadrado do material selecionado." wrapText="true" />
                                <Label styleClass="budget-note-link" text="Painel Admin." />
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>